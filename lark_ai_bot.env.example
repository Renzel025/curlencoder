# Template — copy to lark_ai_bot.env and fill in the real values.
#   cp lark_ai_bot.env.example lark_ai_bot.env
#   chmod 600 lark_ai_bot.env
# The real lark_ai_bot.env is gitignored (*.env) so secrets never reach GitHub.

# --- Lark Custom App (SAME app as encoder_monitor.env) ---
export LARK_APP_ID=""          # cli_xxxxxxxx          <-- FILL IN (same as encoder monitor)
export LARK_APP_SECRET=""      # app secret            <-- FILL IN (same as encoder monitor)

# --- OpenAI (the bot's brain) ---
export OPENAI_API_KEY=""                       # sk-...           <-- FILL IN
export OPENAI_MODEL="gpt-4o-mini"              # gpt-4o-mini (cheap) or gpt-4o
export OPENAI_BASE="https://api.openai.com/v1" # change only for an OpenAI-compatible gateway
export OPENAI_TIMEOUT="60"

# How the bot behaves. Edit this to give it a persona / domain knowledge.
export SYSTEM_PROMPT="You are a helpful assistant in a Lark chat. Answer clearly and concisely. Use plain text."

# How many past messages to remember per thread (follow-up context).
export HISTORY_TURNS="12"
