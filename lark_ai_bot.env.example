# Template — copy to lark_ai_bot.env and fill in the real values.
#   cp lark_ai_bot.env.example lark_ai_bot.env
#   chmod 600 lark_ai_bot.env
# The real lark_ai_bot.env is gitignored (*.env) so secrets never reach GitHub.

# --- Lark Custom App (SAME app as encoder_monitor.env) ---
export LARK_APP_ID=""          # cli_xxxxxxxx          <-- FILL IN (same as encoder monitor)
export LARK_APP_SECRET=""      # app secret            <-- FILL IN (same as encoder monitor)
# MUST match your app's cluster, or the long connection fails ("Incorrect domain
# name"). open.larksuite.com = Lark international (same as encoder_monitor.env);
# open.feishu.cn = Feishu (China).
export LARK_DOMAIN="https://open.larksuite.com"

# --- OpenAI (the bot's brain) ---
export OPENAI_API_KEY=""                       # sk-...           <-- FILL IN
export OPENAI_MODEL="gpt-4o-mini"              # gpt-4o-mini (cheap) or gpt-4o
export OPENAI_BASE="https://api.openai.com/v1" # change only for an OpenAI-compatible gateway
export OPENAI_TIMEOUT="60"

# How the bot behaves. Edit this to give it a persona / domain knowledge.
export SYSTEM_PROMPT="You are a helpful assistant in a Lark chat. Answer clearly and concisely. Use plain text."

# How many past messages to remember per thread (follow-up context).
export HISTORY_TURNS="12"

# Emoji reactions on your message: one when the bot starts ("got it"), one when
# it finishes ("done"). Set REACTIONS="0" to disable. Values are Lark emoji_type
# keys (e.g. OnIt, DONE, THUMBSUP, OK). Requires the im:message.reaction scope.
export REACTIONS="1"
export REACT_ACK="OnIt"     # reaction when the bot receives your message
export REACT_DONE="DONE"    # reaction after the bot has replied

# --- Encoder access (needed for the bot's check_encoder tool) ---
# Same values as encoder_monitor.env — lets "@bot check <ip>" actually curl the
# encoder at http://<ip>/get_output and report its TRTC/Agora config.
export ENCODER_SCHEME="http"        # http or https
export ENCODER_USER="admin"         # digest auth user
export ENCODER_PASS="admin"         # digest auth password   <-- FILL IN
export ENCODER_TIMEOUT="10"
export ENCODER_INPUT="0"            # input index (single-HDMI boxes = 0)
