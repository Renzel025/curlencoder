# Template — copy to encoder_monitor.env and fill in the real values.
#   cp encoder_monitor.env.example encoder_monitor.env
#   chmod 600 encoder_monitor.env
# The real encoder_monitor.env is gitignored so secrets never reach GitHub.

# --- Encoder access (reads http://<ip>/get_output?input=0&output=N) ---
export ENCODER_SCHEME="http"        # http or https
export ENCODER_USER="admin"         # digest auth user
export ENCODER_PASS=""              # digest auth password   <-- FILL IN
export ENCODER_TIMEOUT="10"
export ENCODER_INPUT="0"            # input index (single-HDMI boxes = 0)

# --- Lark Custom App ---
export LARK_DOMAIN="https://open.larksuite.com"   # open.feishu.cn for Feishu
export LARK_APP_ID=""          # cli_xxxxxxxx          <-- FILL IN
export LARK_APP_SECRET=""      # app secret            <-- FILL IN
export LARK_CHAT_ID=""         # OTE group chat_id oc_xxxx  <-- FILL IN

# --- The template Lark Sheet (read IPs from it AND write results back) ---
export LARK_OUT_SHEET_TOKEN=""  # spreadsheet token from the URL  <-- FILL IN
export LARK_OUT_SHEET_ID=""     # tab id (the ?sheet=XXXX in the URL)  <-- FILL IN

# Column layout — change only if your sheet differs from Baccarat.xlsx
export TPL_IP_COL="B"           # column with each encoder's IP
export TPL_REMARK_COL="C"       # column with Agora/QAT/SDK TRTC labels
export TPL_PARAM_COL="D"        # column with RoomID/UserID/... labels
export TPL_STREAM_COLS="E,F,G"  # Mainstream, Substream 1, Substream 2
export TPL_OUTPUTS="0,1,2"      # encoder outputs mapped to the columns above (0=Main)

export REQUEST_TIMEOUT="30"
