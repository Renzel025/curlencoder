# Template — copy to encoder_monitor.env and fill in the real values.
#   cp encoder_monitor.env.example encoder_monitor.env
#   chmod 600 encoder_monitor.env
# The real encoder_monitor.env is gitignored so secrets never reach GitHub.

# --- Encoder source ---
# IPs come from the Lark sheet (INPUT section). These apply to every encoder curl:
export ENCODER_PATH="/get_status"   # shared path on every encoder
export ENCODER_SCHEME="http"        # http or https
export ENCODER_USER="admin"         # digest auth user (same for all encoders)
export ENCODER_PASS=""              # digest auth password  <-- FILL IN
export ENCODER_TIMEOUT="10"

# --- Lark Custom App ---
export LARK_DOMAIN="https://open.larksuite.com"   # use https://open.feishu.cn for Feishu
export LARK_APP_ID=""          # cli_xxxxxxxx        <-- FILL IN
export LARK_APP_SECRET=""      # app secret          <-- FILL IN
export LARK_DOC_ID=""          # docx id (only if not using the output sheet)
export LARK_CHAT_ID=""         # OTE group chat_id oc_xxxx  <-- FILL IN

# --- INPUT: Lark Sheet holding the encoder IP list (all-prod-tables) ---
export LARK_IP_SHEET_TOKEN=""  # spreadsheet token from the URL  <-- FILL IN
export LARK_IP_SHEET_NAME=""   # tab name; blank = first sheet
export LARK_IP_SECTION="baccarat"   # game/section in column A (case-insensitive)
export LARK_IP_LABEL_COL="A"        # column with the game/section names
export LARK_IP_VALUE_COL="C"        # column with the encoder IPs

# --- OUTPUT: Lark Sheet to write parsed results into ---
export LARK_OUT_SHEET_TOKEN=""  # destination spreadsheet token  <-- FILL IN
export LARK_OUT_SHEET_ID=""     # tab id (the ?sheet=XXXX in the URL)  <-- FILL IN

export REQUEST_TIMEOUT="30"
