# Template — copy to encoder_monitor.env and fill in the real values.
#   cp encoder_monitor.env.example encoder_monitor.env
#   chmod 600 encoder_monitor.env
# The real encoder_monitor.env is gitignored so secrets never reach GitHub.

# --- Encoder access (reads http://<ip>/get_output?input=0&output=N) ---
export ENCODER_SCHEME="http"        # http or https
export ENCODER_USER="admin"         # digest auth user
export ENCODER_PASS=""              # digest auth password   <-- FILL IN
export ENCODER_TIMEOUT="10"
export ENCODER_INPUT="0"            # input index (single-HDMI boxes = 0)

# --- Lark Custom App ---
export LARK_DOMAIN="https://open.larksuite.com"   # open.feishu.cn for Feishu
export LARK_APP_ID=""          # cli_xxxxxxxx          <-- FILL IN
export LARK_APP_SECRET=""      # app secret            <-- FILL IN
export LARK_CHAT_ID=""         # OTE group chat_id oc_xxxx  <-- FILL IN

# --- The template Lark Sheet(s) — read IPs AND write results back ---
# Fill many sheets in one run. Entries separated by COMMAS (names may have spaces).
# Each entry: <name>=<token>@<tab_id>  (name + @tab optional; omit @tab = first tab;
# the token half may also be a full Lark URL).
export LARK_SHEETS="lavie baccarat=TOKEN@TABID, stots baccarat=TOKEN, dheight baccarat=TOKEN, newport baccarat=TOKEN"  # <-- FILL IN

# Column layout — change only if your sheet differs from Baccarat.xlsx
export TPL_IP_COL="B"           # column with each encoder's IP
export TPL_REMARK_COL="C"       # column with Agora/QAT/SDK TRTC labels
export TPL_PARAM_COL="D"        # column with RoomID/UserID/... labels
export TPL_STREAM_COLS="E,F,G"  # Mainstream, Substream 1, Substream 2
export TPL_OUTPUTS="0,1,2"      # encoder outputs mapped to the columns above (0=Main)

export REQUEST_TIMEOUT="30"

# --- Studio mode (optional) — one spreadsheet per studio with 4 tabs ----------
# If set, this TAKES PRIORITY over LARK_SHEETS. Each studio spreadsheet has:
#   Encoder (PC) + Encoder (SDK)  -> block layout (same as Baccarat.xlsx)
#   TRTC + Agora                  -> flat: col A = room codes, col B = the URL
# The PC/SDK tabs are curled to learn each room's Agora + TRTC URL, then the
# TRTC/Agora tabs are filled by matching their col-A room codes to those URLs.
#
# One entry per line:  name|token|pc_tab|sdk_tab|trtc_tab|agora_tab
#   - token   = the spreadsheet token (the bit in /sheets/<token>) or full URL
#   - *_tab   = each tab's sheet_id (the ?sheet=XXXX in the tab's URL); leave a
#               field empty to skip that tab.
# export LARK_STUDIOS="
# dheights|V03RsV3THhlAfjtq2RNlSRIpgAd|PCTAB|SDKTAB|TRTCTAB|AGORATAB
# lavie|GYvOsizYJhEmPKtPuEwlrAWOgDo|PCTAB|SDKTAB|TRTCTAB|AGORATAB
# "

# How to fill the TRTC tab's URL:
#   scrape    = use the encoder's rtmp_publish_uri that targets TRTC; BLANK if the
#               encoder exposes none (native-TRTC-SDK boxes show no rtmp URL)
#   construct = build it from the trtc_publish_* creds (works for every encoder)
export TRTC_MODE="scrape"
export TRTC_RTMP_HOST="intl-rtmp.rtc.qq.com"   # used only when TRTC_MODE=construct
export TRTC_HOST_MATCH="rtc.qq.com"            # host substring marking a TRTC uri when scraping
